# ============================================================
# CryptoNestX — Environment Variables Template
# Copy to .env and fill real values. NEVER commit .env to git.
# ============================================================

# ── Database ─────────────────────────────────────────────────
POSTGRES_DB=cryptonest
POSTGRES_USER=cryptonest_user
POSTGRES_PASSWORD=CHANGE_ME_strong_password_here

# ── JWT ──────────────────────────────────────────────────────
# Generate with: openssl rand -base64 64
JWT_SECRET=CHANGE_ME_base64_encoded_256bit_secret_key_here
JWT_EXPIRATION_MS=86400000
JWT_REFRESH_EXPIRATION_MS=604800000

# ── Redis ────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_redis_password

# ── Kafka ────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=kafka:9092

# ── Stripe ───────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_CHANGE_ME
STRIPE_WEBHOOK_SECRET=whsec_CHANGE_ME

# ── CoinGecko API ───────────────────────────────────────────
COINGECKO_API_KEY=CHANGE_ME_coingecko_api_key
COINGECKO_BASE_URL=https://api.coingecko.com/api/v3

# ── Email (SMTP) ─────────────────────────────────────────────
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=CHANGE_ME@gmail.com
MAIL_PASSWORD=CHANGE_ME_app_password

# ── Monitoring ───────────────────────────────────────────────
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_grafana_password

# ── SonarQube ───────────────────────────────────────────────
SONAR_TOKEN=CHANGE_ME_sonarqube_token
SONAR_HOST_URL=http://localhost:9000

# ── Docker Hub ──────────────────────────────────────────────
DOCKERHUB_USERNAME=CHANGE_ME
DOCKERHUB_TOKEN=CHANGE_ME_dockerhub_access_token
